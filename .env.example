# Target AI API (drop-in replacement: point your app to http://localhost:8080)
TARGET_API_URL=https://api.openai.com
TARGET_API_KEY=sk-your-key-here

# Vault: leave empty for in-memory only (recommended, data never touches disk)
# Set a path for persistence across restarts (e.g. /app/vault.db)
VAULT_DB_PATH=
VAULT_TTL_SECONDS=3600

# Locale plugins: comma-separated country codes to enable national ID detectors
# Available: it, us, de, fr, gb — leave empty for universal detectors only
LOCALES=

# Universal detectors (always available, toggle per policy)
DETECT_EMAIL=true
DETECT_IBAN=true
DETECT_CREDIT_CARD=true
DETECT_PHONE=true
DETECT_IP=true
DETECT_URL_CREDENTIALS=true

# Name detection (requires at least one LOCALE or uses global fallback dictionary)
DETECT_NAMES=true
